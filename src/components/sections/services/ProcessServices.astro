---
// src/components/sections/services/ProcessServices.astro
---
<section class="border-t border-dashed border-white/15 bg-linear-to-t from-amber-900/20 via-transparent to-transparent text-white py-20">
  <div class="container mx-auto px-6">
    
    <h2 data-reveal class="text-samana-1 text-xs tracking-[0.4em] uppercase font-mono">
      Nuestro Proceso
    </h2>

    {/* Título principal ahora es DORADO (text-samana-1) */}
    <h3 data-reveal-text class="text-4xl md:text-5xl font-serif font-light mt-6 mb-20 tracking-tighter uppercase text-samana-1">
      Cómo trabajamos tu proyecto.
    </h3>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 reveal-group">
      <div class="relative group pt-6">
        {/* Número de fondo: marca de agua sutil (text-white/5) SIN borde dorado */}
        <span class="absolute text-[120px] font-bold text-white/5 -top-16 left-0 transition-all duration-500 group-hover:text-white/10 group-hover:-translate-y-2 pointer-events-none">01</span>
        <div class="relative z-10">
          {/* Subtítulos ahora en BLANCO */}
          <h4 class="text-2xl font-serif uppercase tracking-wide text-white mb-3">
            Asesoramiento
          </h4>
          <p class="text-gray-400 leading-relaxed text-sm">
            Analizamos tu idea, espacio y presupuesto para definir el mejor camino.
          </p>
        </div>
      </div>

      <div class="relative group pt-6">
        <span class="absolute text-[120px] font-bold text-white/5 -top-16 left-0 transition-all duration-500 group-hover:text-white/10 group-hover:-translate-y-2 pointer-events-none">02</span>
        <div class="relative z-10">
          <h4 class="text-2xl font-serif uppercase tracking-wide text-white mb-3">
            Planificación
          </h4>
          <p class="text-gray-400 leading-relaxed text-sm">
            Organización técnica, tiempos, materiales y logística.
          </p>
        </div>
      </div>

      <div class="relative group pt-6">
        <span class="absolute text-[120px] font-bold text-white/5 -top-16 left-0 transition-all duration-500 group-hover:text-white/10 group-hover:-translate-y-2 pointer-events-none">03</span>
        <div class="relative z-10">
          <h4 class="text-2xl font-serif uppercase tracking-wide text-white mb-3">
            Ejecución
          </h4>
          <p class="text-gray-400 leading-relaxed text-sm">
            Mano de obra especializada con control de calidad constante.
          </p>
        </div>
      </div>

      <div class="relative group pt-6">
        <span class="absolute text-[120px] font-bold text-white/5 -top-16 left-0 transition-all duration-500 group-hover:text-white/10 group-hover:-translate-y-2 pointer-events-none">04</span>
        <div class="relative z-10">
          <h4 class="text-2xl font-serif uppercase tracking-wide text-white mb-3">
            Entrega Final
          </h4>
          <p class="text-gray-400 leading-relaxed text-sm">
            Proyecto terminado, funcional y listo para ser vivido.
          </p>
        </div>
      </div>
    </div>

    <div class="mt-24 relative group w-full h-full overflow-hidden rounded-sm border border-white/10 shadow-2xl bg-black/20">
      <div class="absolute inset-0 bg-linear-to-t from-black/60 via-transparent to-transparent z-10 pointer-events-none"></div>
      <button id="video-control" class="absolute inset-0 z-20 flex items-center justify-center bg-black/20 group-hover:bg-black/40 transition-all duration-300" aria-label="Reproducir video">
        <div class="w-20 h-20 flex items-center justify-center rounded-full border border-samana-1/50 bg-black/40 backdrop-blur-sm text-samana-1 transform transition-transform group-hover:scale-110">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 fill-current ml-1" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"></path></svg>
        </div>
      </button>
      <video id="main-video" muted playsinline preload="metadata" poster="/images/projects/Blanco-Encalada/after/habitacion.webp" class="w-full aspect-video object-cover transition-transform duration-700 group-hover:scale-105">
        <source src="/videos/habitacion-blanco-escalada.mp4" type="video/mp4" />
        Tu navegador no soporta videos.
      </video>
    </div>

  </div>
</section>

<script>
  const video = document.getElementById("main-video") as HTMLVideoElement;
  const btn = document.getElementById("video-control") as HTMLButtonElement;

  if(video && btn) {
    window.addEventListener("load", () => {
      video.play().then(() => {
        btn.style.opacity = "0";
      }).catch(() => {
        btn.style.opacity = "1";
      });
    });

    video.onended = () => {
      btn.style.opacity = "1";
    };

    btn.addEventListener("click", () => {
      if (video.paused) {
        video.play();
        btn.style.opacity = "0";
      } else {
        video.pause();
        btn.style.opacity = "1";
      }
    });
  }
</script>

<style>
  #video-control {
    transition: opacity 0.4s ease;
  }
</style>