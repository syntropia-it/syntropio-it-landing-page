<section
  class="border-t border-dashed border-white/15 bg-linear-to-t from-amber-900/20 via-transparent to-transparent text-white py-20"
>
  <div class="container mx-auto px-6">
    <h2
      data-reveal
      class="text-samana-1 text-xs tracking-[0.4em] uppercase font-mono"
    >
      Nuestro Proceso
    </h2>

    <h3 data-reveal-text class="text-5xl font-bold mt-6 mb-20 tracking-tight">
      Cómo trabajamos tu proyecto.
    </h3>

    <div class="grid md:grid-cols-2 gap-20 reveal-group">
      <!-- Paso 1 -->
      <div class="relative">
        <span
          class="absolute text-[150px] font-bold text-transparent opacity-10 -top-22"
          style={`-webkit-text-stroke:3px #ffd700;`}>01</span
        >
        <h4 class="text-3xl font-semibold mb-3 border-b border-samana-1/70">
          Asesoramiento
        </h4>
        <p class="text-white/90">
          Analizamos tu idea, espacio y presupuesto para definir el mejor
          camino.
        </p>
      </div>

      <!-- Paso 2 -->
      <div class="relative">
        <span
          class="absolute text-[150px] font-bold text-transparent opacity-10 -top-22"
          style={`-webkit-text-stroke:3px #ffd700;`}>02</span
        >
        <h4 class="text-3xl font-semibold mb-3 border-b border-samana-1/70">
          Planificación
        </h4>
        <p class="text-white/90">
          Organización técnica, tiempos, materiales y logística.
        </p>
      </div>

      <!-- Paso 3 -->
      <div class="relative">
        <span
          class="absolute text-[150px] font-bold text-transparent opacity-10 -top-22"
          style={`-webkit-text-stroke:3px #ffd700;`}>03</span
        >
        <h4 class="text-3xl font-semibold mb-3 border-b border-samana-1/70">
          Ejecución
        </h4>
        <p class="text-white/90">
          Mano de obra especializada con control de calidad constante.
        </p>
      </div>

      <!-- Paso 4 -->
      <div class="relative">
        <span
          class="absolute text-[150px] font-bold text-transparent opacity-10 -top-22"
          style={`-webkit-text-stroke:3px #ffd700;`}>04</span
        >
        <h4 class="text-3xl font-semibold mb-3 border-b border-samana-1/70">
          Entrega Final
        </h4>
        <p class="text-white/90">
          Proyecto terminado, funcional y listo para ser vivido.
        </p>
      </div>
    </div>
    <div
      class="mt-20 relative group overflow-hidden rounded-2xl border border-white/10 bg-black/20"
    >
      <div
        class="absolute inset-0 bg-linear-to-t from-black/60 via-transparent to-transparent z-10 pointer-events-none"
      >
      </div>
      <button
        id="video-control"
        class="absolute inset-0 z-20 flex items-center justify-center bg-black/20 group-hover:bg-black/40 transition-all duration-300"
        aria-label="Reproducir video"
      >
        <div
          class="w-20 h-20 flex items-center justify-center rounded-full border-2 border-samana-1/50 bg-black/40 backdrop-blur-sm text-samana-1 transform transition-transform group-hover:scale-110"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-10 w-10 fill-current"
            viewBox="0 0 24 24"><path d="M8 5v14l11-7z"></path></svg
          >
        </div>
      </button>
      <video
        id="main-video"
        muted
        playsinline
        preload="metadata"
        poster="/images/Blanco de Encalada 2222/habitacion-blanco-escalada.jpg"
        class="w-full aspect-video object-cover transition-transform duration-700 group-hover:scale-105"
      >
        <source src="/videos/habitacion-blanco-escalada.mp4" type="video/mp4" />
        Tu navegador no soporta videos.
      </video>
    </div>
  </div>
</section>
<script>
  const video = document.getElementById("main-video") as HTMLVideoElement;
  const btn = document.getElementById("video-control") as HTMLButtonElement;

  // 1. Auto-reproducción inicial (una sola vez)
  window.addEventListener("load", () => {
    video
      .play()
      .then(() => {
        // Si el navegador permitió el autoplay, ocultamos el botón
        btn.style.opacity = "0";
      })
      .catch(() => {
        // Si el navegador bloqueó el autoplay, mostramos el botón
        btn.style.opacity = "1";
      });
  });

  // 2. Cuando termine la primera reproducción, mostramos el botón de nuevo
  video.onended = () => {
    btn.style.opacity = "1";
  };

  // 3. Control manual al hacer click
  btn.addEventListener("click", () => {
    if (video.paused) {
      video.play();
      btn.style.opacity = "0";
    } else {
      video.pause();
      btn.style.opacity = "1";
    }
  });
</script>

<style>
  /* Transición suave para el botón */
  #video-control {
    transition: opacity 0.4s ease;
  }
</style>
