---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
const services = (await getCollection('services')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<section class="border-t border-dashed border-white/15 bg-linear-to-t to-amber-900/20 via-transparent from-transparent text-white py-20">
  <div class="container mx-auto px-6">

    <span 
      data-reveal
      class="text-samana-1 text-xs font-mono tracking-[0.4em] uppercase"
    >
      Nuestros Servicios
    </span>

    {/* Título principal ahora es DORADO y alineamos su estilo Serif con el de arriba */}
    <h3 
      data-reveal-text
      class="text-4xl md:text-5xl font-serif font-light mt-6 mb-20 tracking-tighter uppercase text-samana-1"
    >
      Creamos espacios funcionales y duraderos para vos.
    </h3>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 reveal-group">
      {services.map((service) => (
        <a
          href={`/servicios/${service.slug}`}
          class="relative h-100 bg-neutral-900 overflow-hidden group mask-reveal block"
        >
          <div class="absolute inset-0 parallax scale-110">
            <img  
              src={service.data.image}
              alt={service.data.title}              
              loading="lazy" 
              decoding="async"             
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
          </div>

          <div class="absolute inset-0 bg-black/50 transition-all duration-700 group-hover:bg-black/70"></div>

          <div class="absolute bottom-0 left-0 right-0 p-6 mask-content">
            <span class="absolute text-[150px] font-bold text-transparent opacity-30 -top-22"
            style={`-webkit-text-stroke:3px #ffd700;`}>
              0{service.data.order}
            </span>
            
            {/* CORRECCIÓN: Títulos de los servicios en BLANCO */}
            <h4 class="text-2xl font-serif uppercase tracking-wide text-white mb-2">
              {service.data.title}
            </h4>            
            
            {/* El "Ver más" lo dejamos doradito para que llame al click */}
            <span class="text-samana-1 text-xs uppercase tracking-widest opacity-0 translate-y-2 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500">
              Ver más →
            </span>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>