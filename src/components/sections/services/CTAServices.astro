---
// src/components/sections/services/CTAServices.astro
---
<section class="relative bg-linear-to-t from-amber-900/20 to-black text-white py-20 border-t border-white/10 overflow-hidden">
    {/* ACÁ ESTÁ LA MAGIA: text-center, flex, flex-col, items-center */}
    <div class="container mx-auto px-6 relative z-10 flex flex-col items-center text-center">
        <h2 class="text-4xl md:text-6xl font-bold leading-tight max-w-4xl">
            ¿Estás pensando en remodelar tu casa?
        </h2>

        <p class="text-gray-300 max-w-2xl text-lg mx-auto mt-6 mb-12">
            Transformamos espacios para que reflejen tu esencia y tu forma de vivir.
        </p>

        {/* Cambiamos 'flex' por 'inline-flex' para que el botón no se estire */}
        <a
            href="/contacto"
            class="inline-flex items-center justify-center border border-samana-1 text-samana-1 px-10 py-4 uppercase tracking-widest text-xl hover:bg-samana-1 hover:text-black transition"
        >
            Inicia tu Proyecto
        </a>
    </div>
    
    <div class="absolute -bottom-5 sm:-bottom-10 md:-bottom-25 left-0 w-full pointer-events-none select-none z-0">
        <h1
            data-reveal
            class="text-[25vw] font-bold leading-none tracking-tighter uppercase opacity-[0.1] translate-x-[-5%]"
        >
            Samana
        </h1>
    </div>
</section>